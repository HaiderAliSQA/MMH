import { useState, useEffect } from 'react';
import api, { adminAPI } from '../../api';

const ManageUsers = () => {
    const [users, setUsers] = useState([]);
    const [showModal, setShowModal] = useState(false);
    const [loading, setLoading] = useState(false);
    const [search, setSearch] = useState('');
    const [roleFilter, setRoleFilter] = useState('All');
    const [step, setStep] = useState('role'); // role, details
    const [editMode, setEditMode] = useState(false);
    const [selectedUserId, setSelectedUserId] = useState(null);

    const [formData, setFormData] = useState({
        name: '', email: '', password: '', phone: '', role: '', isActive: true,
        doctorData: { dept: '', specialization: '', qualification: '', opdDays: [], opdTiming: '', fee: 0 },
        patientData: { age: '', gender: 'Male', cnic: '', address: '', bloodGroup: '' }
    });

    useEffect(() => { fetchUsers(); }, [search, roleFilter]);

    const fetchUsers = async () => {
        try {
            const res = await adminAPI.getUsers({ search, role: roleFilter });
            setUsers(res.data);
        } catch (err) { console.error(err); }
    };

    const handleRoleSelect = (role) => {
        setFormData({ ...formData, role });
        setStep('details');
    };

    const generatePassword = () => {
        const up = "ABCDEFGHJKLMNPQRSTUVWXYZ";
        const lw = "abcdefghijkmnopqrstuvwxyz";
        const num = "23456789";
        const get = (s, n) => Array.from({length:n}, () => s[Math.floor(Math.random()*s.length)]).join('');
        const pass = get(up, 2) + get(lw, 4) + get(num, 2);
        setFormData({ ...formData, password: pass });
    };

    const handleSubmit = async (e) => {
        e.preventDefault();
        setLoading(true);
        try {
            if (editMode) {
                await adminAPI.updateUser(selectedUserId, formData);
            } else {
                await adminAPI.createUser(formData);
            }
            setShowModal(false);
            fetchUsers();
            resetForm();
        } catch (err) { alert(err.response?.data?.message || 'Error saving user'); }
        finally { setLoading(false); }
    };

    const resetForm = () => {
        setFormData({
            name: '', email: '', password: '', phone: '', role: '', isActive: true,
            doctorData: { dept: '', specialization: '', qualification: '', opdDays: [], opdTiming: '', fee: 0 },
            patientData: { age: '', gender: 'Male', cnic: '', address: '', bloodGroup: '' }
        });
        setStep('role');
        setEditMode(false);
        setSelectedUserId(null);
    };

    const openEdit = (u) => {
        setEditMode(true);
        setSelectedUserId(u._id);
        setFormData({ ...formData, ...u, password: '' });
        setStep('details');
        setShowModal(true);
    };

    const toggleStatus = async (u) => {
        try {
            await adminAPI.updateUser(u._id, { ...u, isActive: !u.isActive });
            fetchUsers();
        } catch (err) { console.error(err); }
    };

    return (
        <div className="fade-up">
            <div className="card">
                <div className="card-hd">
                    <h3 className="card-title">User Management</h3>
                    <button className="btn btn-primary" onClick={() => { resetForm(); setShowModal(true); }}>+ Add New User</button>
                </div>

                <div className="filters-row" style={{display:'flex', gap:15, marginBottom:20}}>
                    <input 
                        type="text" className="form-control" placeholder="Search name or email..." 
                        value={search} onChange={(e) => setSearch(e.target.value)} 
                        style={{maxWidth:300}}
                    />
                    <select className="form-control" value={roleFilter} onChange={(e) => setRoleFilter(e.target.value)} style={{maxWidth:150}}>
                        {['All', 'Receptionist', 'Doctor', 'Lab Technician', 'Pharmacist', 'Manager', 'Patient'].map(r => (
                            <option key={r} value={r}>{r}</option>
                        ))}
                    </select>
                </div>

                <div className="tbl-wrap">
                    <table>
                        <thead>
                            <tr><th>#</th><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Actions</th></tr>
                        </thead>
                        <tbody>
                            {users.map((u, i) => (
                                <tr key={u._id}>
                                    <td className="td-mono">{i+1}</td>
                                    <td className="td-bold">{u.name}</td>
                                    <td>{u.email}</td>
                                    <td><span className={`badge b-${u.role === 'Admin' ? 'rose' : 'teal'}`}>{u.role}</span></td>
                                    <td>
                                        <span className={`badge ${u.isActive ? 'b-green' : 'b-amber'}`}>
                                            {u.isActive ? 'Active' : 'Inactive'}
                                        </span>
                                    </td>
                                    <td>
                                        <button className="btn btn-sm btn-ghost" onClick={() => openEdit(u)}>✏️</button>
                                        <button className={`btn btn-sm ${u.isActive ? 'btn-danger' : 'btn-success'}`} onClick={() => toggleStatus(u)}>
                                            {u.isActive ? '🔴' : '🟢'}
                                        </button>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>

            {showModal && (
                <div className="modal-overlay">
                    <div className="modal-content" style={{maxWidth:600}}>
                        <div className="modal-hd">
                            <h3>{editMode ? 'Edit User' : 'Create New User'}</h3>
                            <button className="close-btn" onClick={() => { setShowModal(false); resetForm(); }}>&times;</button>
                        </div>
                        
                        <div className="modal-body">
                            {step === 'role' && !editMode ? (
                                <div>
                                    <h4 style={{marginBottom:15, textAlign:'center'}}>Select Role</h4>
                                    <div className="role-grid-modal" style={{display:'grid', gridTemplateColumns:'repeat(3, 1fr)', gap:10}}>
                                        {['Receptionist', 'Doctor', 'Lab Technician', 'Pharmacist', 'Manager', 'Patient'].map(r => (
                                            <div key={r} className="role-card-sm" onClick={() => handleRoleSelect(r)}>
                                                {r}
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            ) : (
                                <form onSubmit={handleSubmit} className="form-grid">
                                    <div className="form-group" style={{gridColumn:'1/-1'}}>
                                        <label>Full Name *</label>
                                        <input type="text" required value={formData.name} onChange={e => setFormData({...formData, name:e.target.value})} />
                                    </div>
                                    <div className="form-group">
                                        <label>Email Address *</label>
                                        <input type="email" required disabled={editMode} value={formData.email} onChange={e => setFormData({...formData, email:e.target.value})} />
                                    </div>
                                    <div className="form-group">
                                        <label>Phone Number</label>
                                        <input type="text" value={formData.phone} onChange={e => setFormData({...formData, phone:e.target.value})} />
                                    </div>
                                    <div className="form-group">
                                        <label>Password {editMode ? '(Leave blank to keep same)' : '*'}</label>
                                        <div style={{display:'flex', gap:5}}>
                                            <input type="text" className="td-mono" required={!editMode} value={formData.password} onChange={e => setFormData({...formData, password:e.target.value})} />
                                            {!editMode && <button type="button" className="btn btn-sm btn-ghost" onClick={generatePassword}>🔄</button>}
                                        </div>
                                    </div>
                                    <div className="form-group">
                                        <label>Status</label>
                                        <div style={{display:'flex', alignItems:'center', gap:10, marginTop:10}}>
                                            <input type="checkbox" checked={formData.isActive} onChange={e => setFormData({...formData, isActive:e.target.checked})} /> Active
                                        </div>
                                    </div>

                                    {formData.role === 'Doctor' && (
                                        <>
                                            <div className="form-sep" style={{gridColumn:'1/-1', borderTop:'1px solid var(--border)', margin:'10px 0'}}></div>
                                            <div className="form-group">
                                                <label>Department *</label>
                                                <select required value={formData.doctorData.dept} onChange={e => setFormData({...formData, doctorData:{...formData.doctorData, dept:e.target.value}})}>
                                                    <option value="">Select</option>
                                                    {['Cardiology', 'Neurology', 'Orthopedics', 'General Medicine', 'Pediatrics', 'Gynecology'].map(d => <option key={d} value={d}>{d}</option>)}
                                                </select>
                                            </div>
                                            <div className="form-group">
                                                <label>Qualification</label>
                                                <input type="text" placeholder="MBBS, FCPS" value={formData.doctorData.qualification} onChange={e => setFormData({...formData, doctorData:{...formData.doctorData, qualification:e.target.value}})} />
                                            </div>
                                            <div className="form-group">
                                                <label>Consultation Fee (PKR)</label>
                                                <input type="number" value={formData.doctorData.fee} onChange={e => setFormData({...formData, doctorData:{...formData.doctorData, fee:e.target.value}})} />
                                            </div>
                                            <div className="form-group" style={{gridColumn:'1/-1'}}>
                                                <label>OPD Days</label>
                                                <div style={{display:'flex', flexWrap:'wrap', gap:10, marginTop:5}}>
                                                    {['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'].map(day => (
                                                        <label key={day} style={{fontSize:12}}>
                                                            <input 
                                                                type="checkbox" 
                                                                checked={formData.doctorData.opdDays.includes(day)}
                                                                onChange={(e) => {
                                                                    const days = e.target.checked 
                                                                        ? [...formData.doctorData.opdDays, day]
                                                                        : formData.doctorData.opdDays.filter(d => d !== day);
                                                                    setFormData({...formData, doctorData:{...formData.doctorData, opdDays:days}});
                                                                }}
                                                            /> {day}
                                                        </label>
                                                    ))}
                                                </div>
                                            </div>
                                        </>
                                    )}

                                    {formData.role === 'Patient' && (
                                        <>
                                            <div className="form-sep" style={{gridColumn:'1/-1', borderTop:'1px solid var(--border)', margin:'10px 0'}}></div>
                                            <div className="form-group">
                                                <label>Age *</label>
                                                <input type="text" required value={formData.patientData.age} onChange={e => setFormData({...formData, patientData:{...formData.patientData, age:e.target.value}})} />
                                            </div>
                                            <div className="form-group">
                                                <label>Gender *</label>
                                                <select required value={formData.patientData.gender} onChange={e => setFormData({...formData, patientData:{...formData.patientData, gender:e.target.value}})}>
                                                    <option value="Male">Male</option>
                                                    <option value="Female">Female</option>
                                                    <option value="Other">Other</option>
                                                </select>
                                            </div>
                                            <div className="form-group">
                                                <label>CNIC *</label>
                                                <input type="text" required value={formData.patientData.cnic} onChange={e => setFormData({...formData, patientData:{...formData.patientData, cnic:e.target.value}})} />
                                            </div>
                                            <div className="form-group">
                                                <label>Blood Group</label>
                                                <select value={formData.patientData.bloodGroup} onChange={e => setFormData({...formData, patientData:{...formData.patientData, bloodGroup:e.target.value}})}>
                                                    <option value="">Select</option>
                                                    {['A+', 'A-', 'B+', 'B-', 'AB+', 'AB-', 'O+', 'O-'].map(b => <option key={b} value={b}>{b}</option>)}
                                                </select>
                                            </div>
                                        </>
                                    )}

                                    <div className="modal-ft" style={{gridColumn:'1/-1', marginTop:20}}>
                                        <button type="submit" className="btn btn-primary w-100" disabled={loading}>
                                            {loading ? 'Saving...' : editMode ? 'Update User' : 'Create User'}
                                        </button>
                                    </div>
                                </form>
                            )}
                        </div>
                    </div>
                </div>
            )}
        </div>
    );
};

export default ManageUsers;
